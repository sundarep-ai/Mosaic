# Secret key for signing session cookies (use a long random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-random-secret-key

# Optional: set to a OneDrive/cloud folder path for cloud-synced backups
# If not set, backups are stored locally in backend/data/backups/
# BACKUP_PATH=C:/Users/yourname/OneDrive/Mosaic-Backups
