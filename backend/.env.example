# Passwords must be bcrypt hashes. Generate with:
#   python -c "from auth import hash_password; print(hash_password('yourpassword'))"
USER_A_PASSWORD=$2b$12$examplehashreplaceme000000000000000000000000000000
USER_B_PASSWORD=$2b$12$examplehashreplaceme000000000000000000000000000000

# Secret key for signing session cookies (use a long random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-random-secret-key

# Optional: set to a OneDrive/cloud folder path for cloud-synced backups
# If not set, backups are stored locally in backend/data/backups/
BACKUP_PATH=C:/Users/yourname/OneDrive/MosaicTally-Backups
