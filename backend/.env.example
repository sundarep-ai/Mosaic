# Secret key for signing session cookies (use a long random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-random-secret-key

# ── Production settings ───────────────────────────────────────────────────────

# Set to "production" to enable production logging and behaviour.
# Leave as "development" (default) for local dev.
# ENV=production

# Override cookie Secure flag independently of ENV.
# Set to "false" for HTTP-only (local network) deployments without HTTPS.
# Set to "true" for HTTPS deployments.
# If unset, defaults to: false when ENV=development, true when ENV=production.
# COOKIE_SECURE=false

# Comma-separated list of allowed CORS origins.
# Not needed when FastAPI serves the frontend directly (git clone method)
# or when behind a same-origin nginx reverse proxy (Docker method).
# Defaults to http://localhost:5173 for local development.
# CORS_ORIGINS=http://localhost:5173

# Directory for database, backups, audit logs, and avatar uploads.
# Defaults to the backend/ directory.
# In Docker, this is set to /app/data (a mounted volume) automatically.
# DATA_DIR=/app/data

# ── Optional backup settings ─────────────────────────────────────────────────

# Set to a OneDrive/cloud folder path for cloud-synced backups.
# If not set, backups are stored in DATA_DIR/backups/ (or backend/data/backups/).
# BACKUP_PATH=C:/Users/yourname/OneDrive/Mosaic-Backups
