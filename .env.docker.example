# Required: secret key for signing session cookies
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-random-secret

# Optional: which published image version to run (default: latest)
# Pin a specific release for reproducible deploys, e.g. MOSAIC_VERSION=2.0.0
# MOSAIC_VERSION=latest

# Optional: override the host port Mosaic is published on (default: 8000)
# MOSAIC_PORT=8080

# Optional: set to "true" only if you are serving over HTTPS
# COOKIE_SECURE=true

# Optional: path for cloud-synced backups (e.g. a mounted OneDrive folder)
# BACKUP_PATH=/mnt/onedrive/Mosaic-Backups
